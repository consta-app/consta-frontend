# URL del backend Consta (consta-backend)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Cambia a "false" cuando el backend esté listo y conectado
NEXT_PUBLIC_USE_MOCKS=true

# Pinata (IPFS) — solo necesarias si lib/ipfs.ts las usa en cliente
# La Persona 1 puede preferir mover la subida a IPFS al backend.
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud
PINATA_API_KEY=
PINATA_SECRET_KEY=
